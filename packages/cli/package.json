{
  "name": "specflow",
  "version": "0.1.0",
  "description": "SpecFlow CLI — generate production backends from specifications",
  "type": "module",
  "bin": {
    "specflow": "./dist/index.js"
  },
  "files": ["dist", "templates"],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@specflow/core": "file:../core",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "inquirer": "^9.2.0",
    "ora": "^8.0.0",
    "handlebars": "^4.7.8",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "@types/inquirer": "^9.0.0",
    "tsx": "^4.7.0"
  },
  "keywords": ["cli", "backend", "generator", "llm", "typescript", "api", "specflow"],
  "author": "Suhail Taj <suhailtajshaik@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"

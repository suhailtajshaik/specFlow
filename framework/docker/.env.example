# =============================================================================
# LLM Backend Framework Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Gateway Configuration
# -----------------------------------------------------------------------------
PORT=3000

# LLM Provider (llamacpp, gemini, claude, vllm)
LLM_PROVIDER=llamacpp

# Vector Database
QDRANT_URL=http://localhost:6333

# Cache
REDIS_URL=redis://localhost:6379

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/app
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

# Authentication
JWT_SECRET=your-secret-key-change-in-production
API_KEYS=key1,key2,key3

# -----------------------------------------------------------------------------
# LLM Provider Configuration
# -----------------------------------------------------------------------------

# LlamaCpp
LLAMACPP_BASE_URL=http://localhost:8080/v1
LLAMACPP_MODEL=qwen2.5-7b
LLAMACPP_EMBEDDING_MODEL=text-embedding

# Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash-exp
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Claude
ANTHROPIC_API_KEY=your-anthropic-api-key
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# vLLM
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=qwen2.5-7b-instruct

# -----------------------------------------------------------------------------
# Build Pipeline Configuration
# -----------------------------------------------------------------------------

# Source directory for markdown specs
SOURCE_DIR=./example/requirements

# Chunking configuration
CHUNK_MAX_TOKENS=512
CHUNK_OVERLAP_TOKENS=50

# Embedding configuration
EMBEDDING_PROVIDER=llamacpp
EMBEDDING_BATCH_SIZE=64

# Output directory for build artifacts
BUILD_OUTPUT_DIR=/tmp
BUILD_MANIFEST_PATH=/tmp/build-manifest.json
ACTIVE_COLLECTION_PATH=/tmp/.active-collection

# -----------------------------------------------------------------------------
# Email Configuration (MCP Email Server)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
SMTP_FROM_EMAIL=your-email@example.com
EMAIL_TEMPLATE_DIR=/app/templates

# -----------------------------------------------------------------------------
# Docker Configuration
# -----------------------------------------------------------------------------

# LlamaCpp Docker
LLAMACPP_MODEL_PATH=./models
LLAMACPP_MODEL=qwen2.5-7b-instruct-q4_k_m.gguf

# vLLM Docker
VLLM_MODEL_PATH=./models
VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# -----------------------------------------------------------------------------
# Optional: Rate Limiting & Logging
# -----------------------------------------------------------------------------

# Rate limiting (uses Redis)
ENABLE_RATE_LIMITING=true

# Logging level (debug, info, warn, error)
LOG_LEVEL=info

# Request tracing
ENABLE_TRACING=true

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------

# CORS origins (comma separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Trusted proxy IPs (for rate limiting by real IP)
TRUSTED_PROXIES=127.0.0.1

# Maximum request body size (in bytes)
MAX_REQUEST_SIZE=10485760

# -----------------------------------------------------------------------------
# Development
# -----------------------------------------------------------------------------

# Enable development mode features
NODE_ENV=production

# Enable hot reloading in development
HOT_RELOAD=false
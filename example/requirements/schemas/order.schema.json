{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://api.example.com/schemas/order.schema.json",
  "title": "Order Schema",
  "description": "Schema for orders and order-related operations",
  "type": "object",
  "definitions": {
    "OrderItem": {
      "type": "object",
      "required": ["product_id", "quantity", "unit_price"],
      "properties": {
        "product_id": {
          "type": "integer",
          "description": "Product identifier",
          "minimum": 1
        },
        "quantity": {
          "type": "integer",
          "description": "Quantity of the product",
          "minimum": 1,
          "maximum": 999
        },
        "unit_price": {
          "type": "number",
          "description": "Unit price of the product",
          "minimum": 0,
          "multipleOf": 0.01
        },
        "product_name": {
          "type": "string",
          "description": "Product name (returned in response)",
          "maxLength": 255
        },
        "subtotal": {
          "type": "number",
          "description": "Item subtotal (quantity × unit_price)",
          "minimum": 0,
          "multipleOf": 0.01
        }
      },
      "additionalProperties": false
    },
    "ShippingAddress": {
      "type": "object",
      "required": ["street", "city", "state", "postal_code", "country"],
      "properties": {
        "street": {
          "type": "string",
          "description": "Street address",
          "minLength": 1,
          "maxLength": 255
        },
        "city": {
          "type": "string",
          "description": "City name",
          "minLength": 1,
          "maxLength": 100
        },
        "state": {
          "type": "string",
          "description": "State or province",
          "minLength": 1,
          "maxLength": 100
        },
        "postal_code": {
          "type": "string",
          "description": "Postal or ZIP code",
          "minLength": 1,
          "maxLength": 20
        },
        "country": {
          "type": "string",
          "description": "Country code (ISO 3166-1 alpha-2)",
          "pattern": "^[A-Z]{2}$"
        }
      },
      "additionalProperties": false
    },
    "CreateOrderRequest": {
      "type": "object",
      "required": ["items", "shipping_address", "payment_method"],
      "properties": {
        "items": {
          "type": "array",
          "description": "Order items",
          "minItems": 1,
          "maxItems": 50,
          "items": {
            "$ref": "#/definitions/OrderItem"
          }
        },
        "shipping_address": {
          "$ref": "#/definitions/ShippingAddress"
        },
        "payment_method": {
          "type": "string",
          "description": "Payment method",
          "enum": ["credit_card", "debit_card", "bank_transfer", "digital_wallet"]
        }
      },
      "additionalProperties": false
    },
    "Order": {
      "type": "object",
      "required": [
        "id", "user_id", "status", "total_amount", "currency", 
        "items", "shipping_address", "payment_method", 
        "created_at", "updated_at"
      ],
      "properties": {
        "id": {
          "type": "integer",
          "description": "Unique order identifier",
          "minimum": 1
        },
        "user_id": {
          "type": "integer",
          "description": "User who created the order",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "description": "Order status",
          "enum": ["pending", "confirmed", "shipped", "delivered", "cancelled", "failed"]
        },
        "total_amount": {
          "type": "number",
          "description": "Total order amount",
          "minimum": 0,
          "multipleOf": 0.01
        },
        "currency": {
          "type": "string",
          "description": "Currency code",
          "pattern": "^[A-Z]{3}$",
          "default": "USD"
        },
        "items": {
          "type": "array",
          "description": "Order items with details",
          "minItems": 1,
          "items": {
            "allOf": [
              { "$ref": "#/definitions/OrderItem" },
              {
                "required": ["product_name", "subtotal"]
              }
            ]
          }
        },
        "shipping_address": {
          "$ref": "#/definitions/ShippingAddress"
        },
        "payment_method": {
          "type": "string",
          "description": "Payment method used",
          "enum": ["credit_card", "debit_card", "bank_transfer", "digital_wallet"]
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "Order creation timestamp"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time",
          "description": "Last order update timestamp"
        },
        "confirmation_number": {
          "type": "string",
          "description": "Order confirmation number",
          "pattern": "^ORD-\\d{4}-\\d+-[A-Z0-9]+$"
        }
      },
      "additionalProperties": false
    },
    "Product": {
      "type": "object",
      "required": ["id", "sku", "name", "price", "stock_quantity", "is_active"],
      "properties": {
        "id": {
          "type": "integer",
          "description": "Product identifier",
          "minimum": 1
        },
        "sku": {
          "type": "string",
          "description": "Stock keeping unit",
          "maxLength": 100
        },
        "name": {
          "type": "string",
          "description": "Product name",
          "maxLength": 255
        },
        "description": {
          "type": "string",
          "description": "Product description"
        },
        "price": {
          "type": "number",
          "description": "Current product price",
          "minimum": 0,
          "multipleOf": 0.01
        },
        "stock_quantity": {
          "type": "integer",
          "description": "Available stock quantity",
          "minimum": 0
        },
        "category": {
          "type": "string",
          "description": "Product category",
          "maxLength": 100
        },
        "is_active": {
          "type": "boolean",
          "description": "Whether the product is active",
          "default": true
        }
      },
      "additionalProperties": false
    },
    "ApiResponse": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "integer",
          "description": "HTTP status code",
          "minimum": 100,
          "maximum": 599
        },
        "data": {
          "description": "Response data (null on error)"
        },
        "error": {
          "type": ["object", "null"],
          "description": "Error information (null on success)",
          "properties": {
            "code": {
              "type": "string",
              "description": "Error code"
            },
            "message": {
              "type": "string", 
              "description": "Human-readable error message"
            },
            "details": {
              "type": "object",
              "description": "Additional error details"
            }
          },
          "required": ["code", "message"]
        }
      },
      "additionalProperties": false
    }
  }
}
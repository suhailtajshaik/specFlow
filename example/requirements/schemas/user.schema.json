{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://api.example.com/schemas/user.schema.json",
  "title": "User Schema",
  "description": "Schema for user registration and user data",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "description": "Unique user identifier",
      "minimum": 1
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "User's email address",
      "maxLength": 255
    },
    "username": {
      "type": "string",
      "description": "Unique username",
      "minLength": 3,
      "maxLength": 50,
      "pattern": "^[a-zA-Z0-9_-]+$"
    },
    "password": {
      "type": "string",
      "description": "User password (for registration only)",
      "minLength": 8,
      "maxLength": 128
    },
    "first_name": {
      "type": "string",
      "description": "User's first name",
      "maxLength": 100,
      "pattern": "^[a-zA-Z\\s'-]+$"
    },
    "last_name": {
      "type": "string", 
      "description": "User's last name",
      "maxLength": 100,
      "pattern": "^[a-zA-Z\\s'-]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Account creation timestamp"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Last account update timestamp"
    },
    "last_login": {
      "type": "string",
      "format": "date-time",
      "description": "Last login timestamp"
    },
    "is_active": {
      "type": "boolean",
      "description": "Whether the account is active",
      "default": true
    }
  },
  "definitions": {
    "UserRegistration": {
      "type": "object",
      "required": ["email", "username", "password"],
      "properties": {
        "email": { "$ref": "#/properties/email" },
        "username": { "$ref": "#/properties/username" },
        "password": { "$ref": "#/properties/password" },
        "first_name": { "$ref": "#/properties/first_name" },
        "last_name": { "$ref": "#/properties/last_name" }
      },
      "additionalProperties": false
    },
    "UserLogin": {
      "type": "object",
      "required": ["identifier", "password"],
      "properties": {
        "identifier": {
          "type": "string",
          "description": "Email address or username",
          "minLength": 1
        },
        "password": {
          "type": "string",
          "description": "User password",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "UserProfile": {
      "type": "object",
      "properties": {
        "id": { "$ref": "#/properties/id" },
        "email": { "$ref": "#/properties/email" },
        "username": { "$ref": "#/properties/username" },
        "first_name": { "$ref": "#/properties/first_name" },
        "last_name": { "$ref": "#/properties/last_name" },
        "created_at": { "$ref": "#/properties/created_at" },
        "updated_at": { "$ref": "#/properties/updated_at" },
        "last_login": { "$ref": "#/properties/last_login" },
        "is_active": { "$ref": "#/properties/is_active" }
      },
      "required": ["id", "email", "username", "created_at", "is_active"],
      "additionalProperties": false
    },
    "AuthToken": {
      "type": "object",
      "required": ["access_token", "token_type", "expires_at", "expires_in"],
      "properties": {
        "access_token": {
          "type": "string",
          "description": "JWT access token"
        },
        "token_type": {
          "type": "string",
          "enum": ["Bearer"],
          "description": "Token type"
        },
        "expires_at": {
          "type": "string",
          "format": "date-time",
          "description": "Token expiration timestamp"
        },
        "expires_in": {
          "type": "integer",
          "description": "Token expiration time in seconds",
          "minimum": 1
        }
      },
      "additionalProperties": false
    }
  }
}